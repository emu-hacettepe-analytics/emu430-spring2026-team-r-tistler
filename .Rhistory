library(tidyverse)
library(plotly)
library(scales)
panel <- read_csv("data/processed/trnc_panel.csv")
# 1. Grafiği "p" isimli bir objeye kaydediyoruz (Ekranda hemen görünmez)
p <- ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_area(fill = "#ffb6c1", alpha = 0.4) +
geom_line(color = "#d63384", size = 1.2) +
geom_point(color = "#d63384", size = 3) +
scale_y_continuous(labels = label_comma()) +
theme_minimal() +
labs(title = "Total Annual Arrivals (Interactive)")
ggplotly(p)
#| message: false
#| warning: false
#| code-fold: true
#| code-summary: "Click to see Forecasting Code"
model <- lm(arrivals_total ~ year, data = panel)
forecast_2025 <- predict(model, newdata = data.frame(year = 2025))
ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_point(color = "#d63384") +
geom_smooth(method = "lm", color = "#d63384", fill = "#ffb6c1", alpha = 0.2) +
annotate("point", x = 2025, y = forecast_2025, color = "blue", size = 4, shape = 18) +
annotate("text", x = 2025, y = forecast_2025, label = paste("2025 Forecast:", label_comma()(round(forecast_2025))), vjust = -2, color = "blue", fontface = "bold") +
labs(title = "Arrivals Forecast for 2025", subtitle = "Linear growth projection based on historical data", x = "Year", y = "Projected Arrivals") +
theme_minimal()
#| message: false
#| warning: false
#| code-fold: true
#| code-summary: "Click to see the Forecasting Logic"
model <- lm(arrivals_total ~ year, data = panel)
forecast_2027 <- predict(model, newdata = data.frame(year = 2027))
ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_point(color = "#d63384", size = 3) +
geom_smooth(method = "lm", color = "#d63384", fill = "#ffb6c1", alpha = 0.2) +
annotate("point", x = 2027, y = forecast_2027, color = "#007bff", size = 5, shape = 18) +
annotate("text", x = 2027, y = forecast_2027,
label = paste("2027 Target:", label_comma()(round(forecast_2027))),
vjust = -2, color = "#007bff", fontface = "bold") +
scale_x_continuous(breaks = seq(2015, 2027, 2)) +
scale_y_continuous(labels = label_comma()) +
labs(
title = "Strategic Forecast for 2027",
subtitle = "Extrapolating growth trends beyond December 2024",
x = "Year", y = "Projected Arrivals"
) +
theme_minimal()
#| message: false
#| warning: false
#| code-fold: true
#| code-summary: "Click to see the Optimized Forecasting Logic"
# 1. Sadece pandemi sonrası (2022-2024) toparlanma ivmesini baz alıyoruz
# Bu sayede 'V-Shaped Recovery' trendini yakalamış oluyoruz.
model_post_covid <- lm(arrivals_total ~ year, data = panel %>% filter(year >= 2022))
# 2. 2027 yılı için bu yeni ivmeye göre tahmin yapıyoruz
forecast_2027 <- predict(model_post_covid, newdata = data.frame(year = 2027))
# 3. Grafikleme
ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_point(color = "#d63384", size = 3) +
# Çizgiyi tüm yıllarda gösterip, ivmeyi sadece son yıllardan alıyoruz
geom_smooth(data = panel %>% filter(year >= 2022), method = "lm",
color = "#d63384", fill = "#ffb6c1", alpha = 0.2, fullrange = TRUE) +
# 2027 Tahmin Noktası
annotate("point", x = 2027, y = forecast_2027, color = "#007bff", size = 5, shape = 18) +
# Tahmin Etiketi
annotate("text", x = 2027, y = forecast_2027,
label = paste("2027 Target:", label_comma()(round(forecast_2027))),
vjust = -2, color = "#007bff", fontface = "bold") +
scale_x_continuous(breaks = seq(2015, 2027, 2)) +
scale_y_continuous(labels = label_comma()) +
labs(
title = "Strategic Forecast for 2027 (Post-Pandemic Momentum)",
subtitle = "Projecting target volumes based on 2022-2024 recovery speed",
x = "Year", y = "Projected Arrivals"
) +
theme_minimal()
#| message: false
#| warning: false
model_post_covid <- lm(arrivals_total ~ year, data = panel %>% filter(year >= 2022))
forecast_2027 <- predict(model_post_covid, newdata = data.frame(year = 2027))
ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_point(color = "#d63384", size = 3) +
geom_smooth(data = panel %>% filter(year >= 2022), method = "lm",
color = "#d63384", fill = "#ffb6c1", alpha = 0.2, fullrange = TRUE) +
annotate("point", x = 2027, y = forecast_2027, color = "#007bff", size = 5, shape = 18) +
# Yazıyı sağa ve biraz aşağı kaydırdık ki tam görünsün
annotate("text", x = 2026.8, y = forecast_2027,
label = paste("2027 Target:", label_comma()(round(forecast_2027))),
hjust = 1.1, vjust = 1.5, color = "#007bff", fontface = "bold") +
scale_y_continuous(labels = label_comma(), limits = c(0, 4500000)) +
scale_x_continuous(breaks = seq(2015, 2027, 2)) +
labs(
title = "Strategic Forecast for 2027 (Post-Pandemic Momentum)",
subtitle = "Projecting target volumes based on 2022-2024 recovery speed",
x = "Year", y = "Projected Arrivals"
) +
theme_minimal()
