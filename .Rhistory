library(tidyverse)
library(scales)
# Loading processed panel data
panel <- read_csv("data/processed/trnc_panel.csv")
# Visualization: Arrival Trends
ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_area(fill = "#ffb6c1", alpha = 0.3) +
geom_line(color = "#d63384", size = 1.5) +
geom_point(color = "#d63384", size = 4, stroke = 1, fill = "white", shape = 21) +
scale_y_continuous(labels = label_comma()) +
scale_x_continuous(breaks = 2015:2024) +
labs(
title = "Total Annual Arrivals (2015-2024)",
subtitle = "Analysis of historical peaks and the post-pandemic surge",
x = "Year", y = "Total Visitors"
) +
theme_minimal() +
theme(plot.title = element_text(face = "bold", color = "#831843"))
#| message: false
#| warning: false
ggplot(panel, aes(x = year, y = occupancy_pct)) +
geom_col(fill = "#d63384", alpha = 0.6, width = 0.7) +
geom_text(aes(label = paste0(occupancy_pct, "%")), vjust = -0.5, fontface = "bold") +
scale_x_continuous(breaks = 2015:2024) +
labs(
title = "Annual Hotel Occupancy (%)",
x = "Year", y = "Occupancy Rate"
) +
theme_minimal()
