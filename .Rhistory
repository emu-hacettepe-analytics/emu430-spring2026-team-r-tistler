library(tidyverse)
library(scales)
# Loading the dataset
panel <- read_csv("data/processed/trnc_panel.csv")
# Visualization with pink aesthetics
ggplot(panel, aes(x = year, y = arrivals_total)) +
geom_area(fill = "#ffb6c1", alpha = 0.4) +
geom_line(color = "#d63384", size = 1.2) +
geom_point(color = "#d63384", size = 3) +
scale_y_continuous(labels = label_comma()) +
labs(
title = "Total Tourist Arrivals in TRNC (2015-2024)",
x = "Year", y = "Total Arrivals"
) +
theme_minimal()
#| message: false
#| warning: false
# Step 2.1: Plotting Hotel Occupancy (%)
ggplot(panel, aes(x = year, y = occupancy_pct)) +
geom_col(fill = "#d63384", alpha = 0.7) +
geom_text(aes(label = paste0(occupancy_pct, "%")), vjust = -0.5, fontface = "bold") +
labs(
title = "Annual Hotel Occupancy Rates",
x = "Year", y = "Occupancy (%)"
) +
theme_minimal()
